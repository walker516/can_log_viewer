{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CAN Log Viewer",
  "version": "0.1.0",
  "identifier": "local.can-log-viewer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CAN Log Viewer",
        "width": 1180,
        "height": 760,
        "minWidth": 900,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}

